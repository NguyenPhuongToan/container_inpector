ENV=development
MANAGER_EMAIL=manager@example.com

DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/container_inspection
JWT_SECRET=replace_this_with_a_long_random_secret
JWT_EXPIRES_MINUTES=1440
WORKER_JWT_EXPIRES_MINUTES=10080
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GEMINI_API_KEY=

SEED_DEMO_USERS=true
DEMO_WORKER_EMAIL=worker@example.com
DEMO_WORKER_PASSWORD=worker12345
DEMO_MANAGER_EMAIL=manager@example.com
DEMO_MANAGER_PASSWORD=manager12345
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=admin12345

EMAIL_DELIVERY_MODE=outbox
EMAIL_OUTBOX_DIR=reports/email_outbox
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_sender_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your_sender_email@gmail.com
SMTP_USE_TLS=true
